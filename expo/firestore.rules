rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function userId() {
      return request.auth != null ? request.auth.uid : null;
    }

    function isOwner(targetId) {
      return isSignedIn() && userId() == targetId;
    }

    function isAdmin() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/admins/$(userId()));
    }

    function adminRole() {
      return isAdmin()
        ? get(/databases/$(database)/documents/admins/$(userId())).data.role
        : null;
    }

    function isAdminWithRole(allowedRoles) {
      return isAdmin() && (adminRole() in allowedRoles);
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /providers/{providerId} {
      allow read: if isSignedIn();
      allow create: if isOwner(providerId) || isAdmin();
      allow update: if isOwner(providerId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /bookings/{bookingId} {
      allow read: if isSignedIn() && (
        resource.data.clientId == userId() ||
        resource.data.providerId == userId() ||
        isAdmin()
      );

      allow create: if isSignedIn() &&
        request.resource.data.clientId == userId() &&
        request.resource.data.providerId is string &&
        request.resource.data.status is string;

      allow update: if isSignedIn() && (
        resource.data.clientId == userId() ||
        resource.data.providerId == userId() ||
        isAdmin()
      );

      allow delete: if isSignedIn() && (
        resource.data.clientId == userId() ||
        isAdmin()
      );
    }

    match /messages/{messageId} {
      allow read, update, delete: if isSignedIn() && (
        resource.data.senderId == userId() ||
        resource.data.receiverId == userId() ||
        isAdmin()
      );

      allow create: if isSignedIn() &&
        request.resource.data.senderId == userId() &&
        request.resource.data.receiverId is string;
    }

    match /conversations/{conversationId} {
      function isParticipant(participants) {
        return isSignedIn() && userId() in participants;
      }

      allow read: if isParticipant(resource.data.participants) || isAdmin();
      allow create: if isParticipant(request.resource.data.participants);
      allow update: if isParticipant(resource.data.participants) || isAdmin();
      allow delete: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isSignedIn() && request.resource.data.userId == userId();
      allow update: if isOwner(resource.data.userId) || isAdmin();
      allow delete: if isOwner(resource.data.userId) || isAdmin();
    }

    match /disputes/{disputeId} {
      allow read: if isSignedIn() && (
        resource.data.customerId == userId() ||
        resource.data.providerId == userId() ||
        isAdmin()
      );

      allow create: if isSignedIn() &&
        request.resource.data.customerId == userId();

      allow update: if isSignedIn() && (
        resource.data.customerId == userId() ||
        resource.data.providerId == userId() ||
        isAdmin()
      );
    }

    match /disputeMessages/{messageId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() &&
        resource.data.senderId == userId();
      allow delete: if isAdmin();
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() &&
        resource.data.userId == userId();
    }

    match /admins/{adminId} {
      allow read: if isAdmin();
      allow write: if isAdminWithRole(['super_admin']);
    }

    match /tickets/{ticketId} {
      allow read, create, update: if isAdmin();
      allow delete: if isAdminWithRole(['super_admin', 'cs_lead']);
    }

    match /ticketComments/{commentId} {
      allow read, create: if isAdmin();
      allow update: if isAdmin() && resource.data.authorId == userId();
    }

    match /ticketEvents/{eventId} {
      allow read, create: if isAdmin();
    }

    match /adminDisputes/{disputeId} {
      allow read, create, update: if isAdmin();
    }

    match /merchantKYC/{kycId} {
      allow read: if isAdmin() ||
        (isSignedIn() && resource.data.merchantId == userId());
      allow create: if isSignedIn() &&
        request.resource.data.merchantId == userId();
      allow update: if isAdmin();
    }

    match /payouts/{payoutId} {
      allow read: if isAdmin() ||
        (isSignedIn() && resource.data.merchantId == userId());
      allow create, update: if isAdmin();
    }

    match /refunds/{refundId} {
      allow read, create, update: if isAdmin();
    }

    match /adBoosts/{boostId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    match /reportedContent/{reportId} {
      allow read, update: if isAdmin();
      allow create: if isSignedIn();
    }

    match /kbArticles/{articleId} {
      allow read: if true;
      allow create, update: if isAdmin();
      allow delete: if isAdminWithRole(['super_admin']);
    }

    match /notificationTemplates/{templateId} {
      allow read, create, update: if isAdmin();
      allow delete: if isAdminWithRole(['super_admin']);
    }

    match /auditLogs/{logId} {
      allow read, create: if isAdmin();
    }

    match /slaDefinitions/{slaId} {
      allow read: if isAdmin();
      allow write: if isAdminWithRole(['super_admin', 'cs_lead']);
    }

    match /ticketMacros/{macroId} {
      allow read, write: if isAdmin();
    }

    match /featureFlags/{flagKey} {
      allow read, write: if isAdminWithRole(['super_admin']);
    }

    match /systemSettings/{settingId} {
      allow read, write: if isAdminWithRole(['super_admin']);
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
