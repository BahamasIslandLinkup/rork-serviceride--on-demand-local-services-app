rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
    
    function hasAdminRole(role) {
      return isAdmin() && get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role == role;
    }
    
    match /users/{userId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }
    
    match /bookings/{bookingId} {
      allow read: if isAuthenticated() && (
        resource.data.clientId == request.auth.uid ||
        resource.data.providerId == request.auth.uid
      );
      
      allow create: if isAuthenticated() && 
        request.resource.data.clientId == request.auth.uid &&
        request.resource.data.keys().hasAll(['clientId', 'providerId', 'status', 'price', 'category', 'service', 'date', 'time', 'scheduledAt', 'address', 'clientName', 'providerName']);
      
      allow update: if isAuthenticated() && (
        resource.data.clientId == request.auth.uid ||
        resource.data.providerId == request.auth.uid
      );
      
      allow delete: if isAuthenticated() && 
        resource.data.clientId == request.auth.uid;
    }
    
    match /messages/{messageId} {
      allow read: if isAuthenticated() && (
        resource.data.senderId == request.auth.uid ||
        resource.data.receiverId == request.auth.uid
      );
      
      allow create: if isAuthenticated() && 
        request.resource.data.senderId == request.auth.uid;
      
      allow update: if isAuthenticated() && (
        resource.data.senderId == request.auth.uid ||
        resource.data.receiverId == request.auth.uid
      );
      
      allow delete: if isAuthenticated() && 
        resource.data.senderId == request.auth.uid;
    }
    
    match /conversations/{conversationId} {
      allow read: if isAuthenticated() && 
        request.auth.uid in resource.data.participants;
      
      allow create: if isAuthenticated() && 
        request.auth.uid in request.resource.data.participants;
      
      allow update: if isAuthenticated() && 
        request.auth.uid in resource.data.participants;
      
      allow delete: if isAuthenticated() && 
        request.auth.uid in resource.data.participants;
    }
    
    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && 
        resource.data.userId == request.auth.uid;
      
      allow create: if isAuthenticated();
      
      allow update: if isAuthenticated() && 
        resource.data.userId == request.auth.uid;
      
      allow delete: if isAuthenticated() && 
        resource.data.userId == request.auth.uid;
    }
    
    match /disputes/{disputeId} {
      allow read: if isAuthenticated() && (
        resource.data.customerId == request.auth.uid ||
        resource.data.providerId == request.auth.uid
      );
      
      allow create: if isAuthenticated() && 
        request.resource.data.customerId == request.auth.uid;
      
      allow update: if isAuthenticated() && (
        resource.data.customerId == request.auth.uid ||
        resource.data.providerId == request.auth.uid
      );
    }
    
    match /disputeMessages/{messageId} {
      allow read: if isAuthenticated();
      
      allow create: if isAuthenticated();
      
      allow update: if isAuthenticated() && 
        resource.data.senderId == request.auth.uid;
    }
    
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && 
        resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && 
        resource.data.userId == request.auth.uid;
    }
    
    match /admins/{adminId} {
      allow read: if isAdmin();
      allow write: if hasAdminRole('super_admin');
    }
    
    match /tickets/{ticketId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if hasAdminRole('super_admin') || hasAdminRole('cs_lead');
    }
    
    match /ticketComments/{commentId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update: if isAdmin() && resource.data.authorId == request.auth.uid;
    }
    
    match /ticketEvents/{eventId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
    }
    
    match /adminDisputes/{disputeId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update: if isAdmin();
    }
    
    match /merchantKYC/{kycId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.merchantId == request.auth.uid);
      allow create: if isAuthenticated();
      allow update: if isAdmin();
    }
    
    match /payouts/{payoutId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.merchantId == request.auth.uid);
      allow create: if isAdmin();
      allow update: if isAdmin();
    }
    
    match /refunds/{refundId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update: if isAdmin();
    }
    
    match /adBoosts/{boostId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
    
    match /reportedContent/{reportId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
      allow update: if isAdmin();
    }
    
    match /kbArticles/{articleId} {
      allow read: if true;
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if hasAdminRole('super_admin');
    }
    
    match /notificationTemplates/{templateId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if hasAdminRole('super_admin');
    }
    
    match /auditLogs/{logId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
    }
    
    match /slaDefinitions/{slaId} {
      allow read: if isAdmin();
      allow write: if hasAdminRole('super_admin') || hasAdminRole('cs_lead');
    }
    
    match /ticketMacros/{macroId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
    
    match /featureFlags/{flagKey} {
      allow read: if isAdmin();
      allow write: if hasAdminRole('super_admin');
    }
    
    match /systemSettings/{settingId} {
      allow read: if isAdmin();
      allow write: if hasAdminRole('super_admin');
    }
  }
}
